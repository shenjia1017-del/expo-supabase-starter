# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenAI (optional - only if your app uses OpenAI APIs like Vision, TTS, etc.)
# EXPO_PUBLIC_OPENAI_API_KEY=your_openai_api_key_here

# Anthropic / Claude (optional - only if your app calls the Claude API directly from the client)
# EXPO_PUBLIC_ANTHROPIC_API_KEY=your_anthropic_api_key_here
